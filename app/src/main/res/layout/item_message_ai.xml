<?xml version="1.0" encoding="utf-8"?>
<!-- AI chat bubble (incoming) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="start|center_vertical"
    android:orientation="horizontal"
    android:paddingTop="8dp"
    android:paddingEnd="64dp"
    android:paddingBottom="8dp"
    android:paddingStart="0dp">

    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="@string/cd_ai_avatar"
        android:src="@drawable/ic_avatar_ai" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bubble_ai"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="10dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/cd_ai_avatar"
            android:textColor="?attr/colorPrimary"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:autoLink="web"
            android:fontFamily="sans-serif"
            android:textColor="?attr/colorOnSurface"
            android:textColorLink="?attr/colorPrimary"
            android:textSize="14sp"
            android:lineSpacingExtra="2dp"
            tools:text="This is an AI response describing the diagram in detail." />

        <TextView
            android:id="@+id/textTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="6dp"
            android:fontFamily="sans-serif"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="10sp"
            tools:text="10:32" />
    </LinearLayout>
</LinearLayout>
